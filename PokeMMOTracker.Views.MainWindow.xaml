<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="PokeMMOTracker.Views.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:PokeMMOTracker.Views" xmlns:vm="clr-namespace:PokeMMOTracker.Views" Background="#01000000" Title="PokeMMO Tracker" Height="500" Width="370" FontFamily="./Fonts/#Poppins" Foreground="White" WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResizeWithGrip">
  <Grid Margin="10" Background="Transparent">
    <Grid.Effect>
      <DropShadowEffect Color="Black" BlurRadius="8" Opacity="0.5" Direction="320" ShadowDepth="2"/>
    </Grid.Effect>
    <Grid.RowDefinitions>
        <RowDefinition Height="30" /> <!-- Dedicated Drag Handle Row -->
        <RowDefinition Height="*" />  <!-- Rest of the UI -->
    </Grid.RowDefinitions>
    
    <!-- DRAG HANDLE: The only area used to move the window -->
    <Border Grid.Row="0" Background="#1AFFFFFF" CornerRadius="5" Cursor="SizeAll" MouseLeftButtonDown="DragHandle_MouseDown">
        <TextBlock Text="DRAG HERE" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#55FFFFFF" FontSize="10" FontFamily="./Fonts/#Poppins" FontWeight="Bold" IsHitTestVisible="False"/>
    </Border>

    <!-- The original RootGrid containing the dynamic UI, now placed in Row 1 -->
    <Grid Name="RootGrid" Grid.Row="1" />
  </Grid>
</Window>