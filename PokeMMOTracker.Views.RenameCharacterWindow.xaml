<?xml version="1.0" encoding="utf-8"?>



<Window x:Class="PokeMMOTracker.Views.RenameCharacterWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:PokeMMOTracker.Views" Background="#CC1A1A1A" Title="Rename character" Height="560" Width="480" FontFamily="./Fonts/#Poppins, Segoe UI" Foreground="#DDDDDD" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">



  <Grid Margin="20">



    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">



      <TextBlock Name="TitleText" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,16" Foreground="White"/>



      <TextBlock Name="NameLabel" FontSize="11" Margin="0,0,0,6" Foreground="#B0B0B0"/>



      <TextBox Name="CharacterNameTB" Visibility="Collapsed" MaxLength="16"/>



      <StackPanel Name="KeyboardHost" Margin="0,0,0,4"/>



      <TextBlock Name="KeyboardHintText" FontSize="9" Foreground="#777777" Margin="0,0,0,16" TextAlignment="Center" TextWrapping="Wrap"/>



      <Button Name="SaveBtn" FontWeight="SemiBold" Foreground="White" Background="#3D6B9E" BorderBrush="#6A9FD4" BorderThickness="1" Padding="10,10" Margin="0,0,0,8" Click="SaveBtn_Click">



        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>



      </Button>



      <Button Name="CancelBtn" Foreground="#CCCCCC" Background="#331A1A1A" BorderBrush="#444444" BorderThickness="1" Padding="10,8" Click="CancelBtn_Click">



        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>



      </Button>



    </StackPanel>



  </Grid>



</Window>

