<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="PokeMMOTracker.Views.DialogWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:PokeMMOTracker.Views" Background="#CC1A1A1A" Title="New character" Height="400" Width="340" FontFamily="./Fonts/#Poppins, Segoe UI" Foreground="#DDDDDD" WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="260">
      <TextBlock Name="TitleText" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="White"/>
      <TextBlock Name="NameLabel" FontSize="11" Margin="0,0,0,6" Foreground="#B0B0B0"/>
      <TextBox Name="CharacterNameTB" Padding="10,8" MaxLength="16" Foreground="#F0F0F0" Background="#2A2A2A" BorderBrush="#555555" BorderThickness="1" CaretBrush="White"/>
      <TextBlock Name="RegionLabel" FontSize="11" Margin="0,14,0,8" Foreground="#B0B0B0"/>
      <WrapPanel Name="RegionChips" HorizontalAlignment="Center" Margin="0,0,0,20"/>
      <Button Name="ContinueBtn" FontWeight="SemiBold" Foreground="White" Background="#3D6B9E" BorderBrush="#6A9FD4" BorderThickness="1" Padding="10,10" Margin="0,0,0,8" Click="Button_Click">
        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
      </Button>
      <Button Name="BackBtn" Foreground="#CCCCCC" Background="#331A1A1A" BorderBrush="#444444" BorderThickness="1" Padding="10,8" Click="BackBtn_Click">
        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
      </Button>
    </StackPanel>
  </Grid>
</Window>
