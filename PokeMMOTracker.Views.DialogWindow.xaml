<?xml version="1.0" encoding="utf-8"?>



<Window x:Class="PokeMMOTracker.Views.DialogWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:PokeMMOTracker.Views" Background="#CC1A1A1A" Title="New character" Height="720" Width="480" FontFamily="./Fonts/#Poppins, Segoe UI" Foreground="#DDDDDD" WindowStartupLocation="CenterScreen">



  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">



    <Grid Margin="20">



      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">



        <TextBlock Name="TitleText" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,16" Foreground="White"/>



        <TextBlock Name="NameLabel" FontSize="11" Margin="0,0,0,6" Foreground="#B0B0B0"/>



        <TextBox Name="CharacterNameTB" Visibility="Collapsed" MaxLength="16"/>



        <StackPanel Name="KeyboardHost" Margin="0,0,0,4"/>



        <TextBlock Name="KeyboardHintText" FontSize="9" Foreground="#777777" Margin="0,0,0,12" TextAlignment="Center" TextWrapping="Wrap"/>



        <TextBlock Name="AvatarLabel" FontSize="11" Margin="0,0,0,8" Foreground="#B0B0B0"/>



        <Button Name="AvatarPickBtn" Padding="8" Margin="0,0,0,14" Background="#331A1A1A" BorderBrush="#555555" BorderThickness="1" Click="AvatarPickBtn_Click" Cursor="Hand">



          <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>



          <Image Name="AvatarPreviewImage" Width="72" Height="72" Stretch="UniformToFill"/>



        </Button>



        <TextBlock Name="RegionLabel" FontSize="11" Margin="0,0,0,8" Foreground="#B0B0B0"/>



        <WrapPanel Name="RegionChips" HorizontalAlignment="Center" Margin="0,0,0,20"/>



        <Button Name="ContinueBtn" FontWeight="SemiBold" Foreground="White" Background="#3D6B9E" BorderBrush="#6A9FD4" BorderThickness="1" Padding="10,10" Margin="0,0,0,8" Click="Button_Click">



          <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>



        </Button>



        <Button Name="BackBtn" Foreground="#CCCCCC" Background="#331A1A1A" BorderBrush="#444444" BorderThickness="1" Padding="10,8" Click="BackBtn_Click">



          <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>



        </Button>



      </StackPanel>



    </Grid>



  </ScrollViewer>



</Window>

