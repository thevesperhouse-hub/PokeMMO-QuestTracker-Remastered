<?xml version="1.0" encoding="utf-8"?>

<Window x:Class="PokeMMOTracker.Views.LoginWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="PokeMMO-QT"

        Height="720"

        Width="920"

        MinHeight="640"

        MinWidth="880"

        Background="#CC1A1A1A"

        FontFamily="./Fonts/#Poppins, Segoe UI"

        Foreground="#DDDDDD"

        WindowStartupLocation="CenterScreen">

  <Window.Resources>

    <Style x:Key="HubScrollThumb" TargetType="Thumb">

      <Setter Property="OverridesDefaultStyle" Value="True"/>

      <Setter Property="IsTabStop" Value="False"/>

      <Setter Property="Template">

        <Setter.Value>

          <ControlTemplate TargetType="Thumb">

            <Border x:Name="thumb"

                    CornerRadius="4"

                    Margin="1,2"

                    Background="#4A5568"

                    BorderBrush="#33FFFFFF"

                    BorderThickness="1"/>

            <ControlTemplate.Triggers>

              <Trigger Property="IsMouseOver" Value="True">

                <Setter TargetName="thumb" Property="Background" Value="#5C7A9E"/>

                <Setter TargetName="thumb" Property="BorderBrush" Value="#66A0C8E8"/>

              </Trigger>

              <Trigger Property="IsDragging" Value="True">

                <Setter TargetName="thumb" Property="Background" Value="#6A9FD4"/>

                <Setter TargetName="thumb" Property="BorderBrush" Value="#99C8E8FF"/>

              </Trigger>

            </ControlTemplate.Triggers>

          </ControlTemplate>

        </Setter.Value>

      </Setter>

    </Style>



    <Style TargetType="ScrollBar">

      <Setter Property="OverridesDefaultStyle" Value="True"/>

      <Setter Property="Width" Value="10"/>

      <Setter Property="MinWidth" Value="10"/>

      <Setter Property="Background" Value="Transparent"/>

      <Setter Property="Template">

        <Setter.Value>

          <ControlTemplate TargetType="ScrollBar">

            <Grid x:Name="root" Background="Transparent" Width="10">

              <Border Margin="2,4"

                      CornerRadius="5"

                      Background="#22000000"

                      BorderBrush="#18FFFFFF"

                      BorderThickness="1"/>

              <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="2,6">

                <Track.DecreaseRepeatButton>

                  <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" IsTabStop="False"/>

                </Track.DecreaseRepeatButton>

                <Track.IncreaseRepeatButton>

                  <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" IsTabStop="False"/>

                </Track.IncreaseRepeatButton>

                <Track.Thumb>

                  <Thumb Style="{StaticResource HubScrollThumb}"/>

                </Track.Thumb>

              </Track>

            </Grid>

            <ControlTemplate.Triggers>

              <Trigger Property="Orientation" Value="Horizontal">

                <Setter TargetName="root" Property="LayoutTransform">

                  <Setter.Value>

                    <RotateTransform Angle="-90"/>

                  </Setter.Value>

                </Setter>

                <Setter TargetName="root" Property="Width" Value="Auto"/>

                <Setter TargetName="root" Property="Height" Value="10"/>

              </Trigger>

            </ControlTemplate.Triggers>

          </ControlTemplate>

        </Setter.Value>

      </Setter>

    </Style>

  </Window.Resources>



  <Grid Margin="20,16,20,16">

    <Grid.RowDefinitions>

      <RowDefinition Height="Auto"/>

      <RowDefinition Height="*"/>

      <RowDefinition Height="Auto"/>

    </Grid.RowDefinitions>



    <StackPanel Grid.Row="0" Margin="0,0,0,12">

      <TextBlock Name="HubTitleText" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>

      <TextBlock Name="HubSubtitleText" FontSize="11" Opacity="0.7" HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">

        <TextBlock Name="LangLabelText" FontSize="10" Foreground="#99AAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>

        <Button Name="LangEnBtn" Content="EN" Width="44" Height="28" Margin="2,0" Padding="0" FontSize="11" FontWeight="SemiBold" Foreground="White" Background="#55333333" BorderBrush="#55FFFFFF" BorderThickness="1" Click="LangEnBtn_Click">

          <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>

        </Button>

        <Button Name="LangFrBtn" Content="FR" Width="44" Height="28" Margin="2,0" Padding="0" FontSize="11" FontWeight="SemiBold" Foreground="White" Background="#55333333" BorderBrush="#55FFFFFF" BorderThickness="1" Click="LangFrBtn_Click">

          <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>

        </Button>

      </StackPanel>

    </StackPanel>



    <Grid Grid.Row="1">

      <ScrollViewer Name="CardsScroller"

                  VerticalScrollBarVisibility="Auto"

                  HorizontalScrollBarVisibility="Disabled"

                  Margin="0,0,0,8"

                  Padding="0,0,2,8">

      <StackPanel Name="CardsPanel" HorizontalAlignment="Center"/>

    </ScrollViewer>

      <Border Name="NavHighlightRing" Visibility="Collapsed" IsHitTestVisible="False"

              BorderBrush="#FFCC00" BorderThickness="3" CornerRadius="8"

              Background="#443D6B9E" HorizontalAlignment="Left" VerticalAlignment="Top"/>

    </Grid>



    <Border Grid.Row="2" Padding="0,12,0,0" BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0">

      <StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">

          <CheckBox Name="RememberMeCheckBox" Style="{DynamicResource ModernCheck}" Margin="0,0,24,0" VerticalAlignment="Center"/>

          <CheckBox Name="RememberScroll" Style="{DynamicResource ModernCheck}" VerticalAlignment="Center"/>

        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">

          <CheckBox Name="NarratorEnabledCheckBox" Style="{DynamicResource ModernCheck}" Margin="0,0,24,0" VerticalAlignment="Center"/>

          <CheckBox Name="NarratorNeuralCheckBox" Style="{DynamicResource ModernCheck}" VerticalAlignment="Center"/>

        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">

          <CheckBox Name="NarratorAutoReadCheckBox" Style="{DynamicResource ModernCheck}" VerticalAlignment="Center"/>

        </StackPanel>

        <TextBlock Name="NarratorHintText" FontSize="9" Opacity="0.55" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="8,0,8,10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

          <Button Name="NewCharBtn" Padding="14,9" MinWidth="168" Margin="6,0" Background="#661A1A1A" Foreground="White" BorderBrush="#55FFFFFF" BorderThickness="1" Click="NewCharBtn_Click">

            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>

          </Button>

          <Button Name="ChangeTheme" Padding="14,9" MinWidth="120" Margin="6,0" Background="#44111111" Foreground="#DDDDDD" BorderBrush="#40FFFFFF" BorderThickness="1" Click="ChangeTheme_Click">

            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>

          </Button>

        </StackPanel>

      </StackPanel>

    </Border>

  </Grid>

</Window>

